{
  "mjx": {
    "impl": "warp",
    "sim_dt": 0.005,
    "ctrl_dt": 0.02
  },
  "ppo": {
    "num_timesteps": 200000000,
    "num_evals": 20,
    "reward_scaling": 1,
    "episode_length": 1000,
    "normalize_observations": true,
    "action_repeat": 1,
    "num_minibatches": 32,
    "unroll_length": 20,
    "num_updates_per_batch": 4,
    "discounting": 0.97,
    "learning_rate": 0.0003,
    "entropy_cost": 0.005,
    "max_grad_norm": 1,
    "clipping_epsilon": 0.2,
    "num_envs": 4096,
    "batch_size": 512,
    "network_factory": {
      "policy_hidden_layer_sizes": [
        512,
        256,
        128
      ],
      "value_hidden_layer_sizes": [
        512,
        256,
        128
      ],
      "policy_obs_key": "state",
      "value_obs_key": "privileged_state"
    },
    "seed": 0
  }
}
