      </body>
      <body name="humanoid_left_upper_arm" pos="0 0.17 0.06">
        <joint name="humanoid_left_shoulder1" armature="0.0068" axis="2 -1 1" pos="0 0 0" range="-60 85" stiffness="1" type="hinge"/>
        <joint name="humanoid_left_shoulder2" armature="0.0051" axis="0 1 1" pos="0 0 0" range="-60 85" stiffness="1" type="hinge"/>
        <geom name="humanoid_left_uarm" fromto="0 0 0 .16 .16 -.16" size="0.04 0.16" type="capsule"/>
        <body name="humanoid_left_lower_arm" pos=".18 .18 -.18">
          <joint name="humanoid_left_elbow" armature="0.0028" axis="0 -1 -1" pos="0 0 0" range="-90 50" stiffness="0" type="hinge"/>
          <geom name="humanoid_left_larm" fromto="0.01 -0.01 0.01 .17 -.17 .17" size="0.031" type="capsule"/>
          <geom name="humanoid_left_hand" pos=".18 -.18 .18" size="0.04" type="sphere"/>
