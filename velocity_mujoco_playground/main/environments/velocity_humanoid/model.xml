              </body>
            </body>
          </body>
        </body>
      </body>
      <body name="humanoid_right_upper_arm" pos="0 -0.17 0.06">
        <joint name="humanoid_right_shoulder1" armature="0.0068" axis="2 1 1" pos="0 0 0" range="-85 60" stiffness="1" type="hinge"/>
        <joint name="humanoid_right_shoulder2" armature="0.0051" axis="0 -1 1" pos="0 0 0" range="-85 60" stiffness="1" type="hinge"/>
