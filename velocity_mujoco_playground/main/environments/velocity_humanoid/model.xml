              <geom name="humanoid_right_shin" fromto="0 0 0 0 0 -.3" size="0.049" type="capsule"/>
              <body name="humanoid_right_foot" pos="0 0 -0.45">
                <geom name="humanoid_right_foot" pos="0 0 0.1" size="0.075" type="sphere"/>
                <site name="humanoid_right_foot" pos="0 0 0.1"/>
              </body>
            </body>
          </body>
          <body name="humanoid_left_thigh" pos="0 0.1 -0.04">
            <joint name="humanoid_left_hip_x" armature="0.01" axis="-1 0 0" damping="5" pos="0 0 0" range="-25 5" stiffness="10" type="hinge"/>
            <joint name="humanoid_left_hip_z" armature="0.01" axis="0 0 -1" damping="5" pos="0 0 0" range="-60 35" stiffness="10" type="hinge"/>
            <joint name="humanoid_left_hip_y" armature="0.01" axis="0 1 0" damping="5" pos="0 0 0" range="-110 20" stiffness="20" type="hinge"/>
            <geom name="humanoid_left_thigh" fromto="0 0 0 0 -0.01 -.34" size="0.06" type="capsule"/>
            <body name="humanoid_left_shin" pos="0 -0.01 -0.403">
              <joint name="humanoid_left_knee" armature="0.0060" axis="0 -1 0" pos="0 0 .02" range="-160 -2" stiffness="1" type="hinge"/>
              <geom name="humanoid_left_shin" fromto="0 0 0 0 0 -.3" size="0.049" type="capsule"/>
              <body name="humanoid_left_foot" pos="0 0 -0.45">
