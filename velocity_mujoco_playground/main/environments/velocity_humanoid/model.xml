<mujoco model="velocity_humanoid">
  <option timestep="0.005" iterations="10" ls_iterations="20" solver="Newton" integrator="implicitfast">
    <flag eulerdamp="disable"/>
  </option>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba force="1 0 0 1" haze="0.15 0.25 0.35 1" fog="0.75 0.75 0.75 1"/>
    <global azimuth="135" elevation="-25" offwidth="1920" offheight="1080"/>
    <map force="0.005"/>
    <scale forcewidth="0.25" contactwidth="0.4" contactheight="0.15" framelength="5.0" framewidth="0.3"/>
    <quality shadowsize="8192"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.71 0.71 0.71" rgb2="0.71 0.71 0.71" width="800" height="800"/>
    <texture name="grey_squares" builtin="checker" height="800" width="800" rgb1="0.71 0.71 0.71" rgb2="0.71 0.71 0.71" type="2d" mark="edge" markrgb="1 1 1"/>
    <material name="floor" reflectance="0.2" texrepeat="1 1" texuniform="true" texture="grey_squares"/>
    <material name="body" rgba=".7 .5 .3 1" specular="0.9" shininess="0.8"/>
  </asset>

  <default>
    <default class="humanoid">
      <geom type="capsule" material="body"/>
    </default>
    <default class="visual">
      <geom group="2" density="0" contype="0" conaffinity="0"/>
    </default>
    <joint armature="1" damping="1" limited="true"/>
    <motor ctrllimited="true" ctrlrange="-.4 .4"/>
  </default>

  <worldbody>
    <geom name="floor" pos="0 0 0" size="50 50 0.110" friction="1 0.5 0.5" type="plane" material="floor"/>

    <!-- Humanoid -->
    <body name="humanoid" childclass="humanoid" pos="0 0 1.40">
      <light pos="0 0 2" mode="trackcom"/>
      <site name="imu" quat="1.0 0.0 0.0 0.0" pos="0.0 0.0 0.0" />
      <camera name="default" mode="trackcom" pos="-3.022 0.677 0.067" xyaxes="-0.207 -0.978 -0.000 0.171 -0.036 0.985"/>
      <site name="humanoid" size="0.01" pos="0 0 0"/>
      <joint name="humanoid_root" type="free" armature="0" damping="0" limited="false" pos="0 0 0" stiffness="0"/>
      <geom name="humanoid_torso" fromto="0 -.07 0 0 .07 0" size="0.07" type="capsule"/>
      <geom name="humanoid_head" pos="0 0 .19" size=".09" type="sphere"/>
      <geom name="humanoid_uwaist" fromto="-.01 -.06 -.12 -.01 .06 -.12" size="0.06" type="capsule"/>
      <body name="humanoid_lwaist" pos="-.01 0 -0.260" quat="1.000 0 -0.002 0">
