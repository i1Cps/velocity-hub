  <sensor>
    <gyro name="gyro" site="imu" noise="0.01" />
    <accelerometer name="accelerometer" site="imu" noise="0.01" />
    <velocimeter name="local_linvel" site="imu" />
    <frameangvel name="global_angvel" objtype="site" objname="imu" />
    <framelinvel name="global_linvel" objtype="site" objname="imu" />
    <framezaxis name="gravity" objtype="site" objname="imu"/>
    <contact name="left_foot_floor_contact" geom1="humanoid_left_foot" geom2="floor" reduce="mindist" num="1" data="found"/>
    <contact name="right_foot_floor_contact" geom1="humanoid_right_foot" geom2="floor" reduce="mindist" num="1" data="found"/>
    <framelinvel name="left_foot_global_linvel" objtype="site" objname="humanoid_left_foot"/>
    <framelinvel name="right_foot_global_linvel" objtype="site" objname="humanoid_right_foot"/>
    <subtreeangmom name="root_angmom" body="humanoid"/>
  </sensor>

  <actuator>
    <motor gear="100" joint="humanoid_abdomen_y" name="humanoid_abdomen_y"/>
    <motor gear="100" joint="humanoid_abdomen_z" name="humanoid_abdomen_z"/>
    <motor gear="100" joint="humanoid_abdomen_x" name="humanoid_abdomen_x"/>
    <motor gear="100" joint="humanoid_right_hip_x" name="humanoid_right_hip_x"/>
    <motor gear="100" joint="humanoid_right_hip_z" name="humanoid_right_hip_z"/>
    <motor gear="300" joint="humanoid_right_hip_y" name="humanoid_right_hip_y"/>
    <motor gear="200" joint="humanoid_right_knee" name="humanoid_right_knee"/>
    <motor gear="100" joint="humanoid_left_hip_x" name="humanoid_left_hip_x"/>
    <motor gear="100" joint="humanoid_left_hip_z" name="humanoid_left_hip_z"/>
    <motor gear="300" joint="humanoid_left_hip_y" name="humanoid_left_hip_y"/>
    <motor gear="200" joint="humanoid_left_knee" name="humanoid_left_knee"/>
    <motor gear="25" joint="humanoid_right_shoulder1" name="humanoid_right_shoulder1"/>
    <motor gear="25" joint="humanoid_right_shoulder2" name="humanoid_right_shoulder2"/>
    <motor gear="25" joint="humanoid_right_elbow" name="humanoid_right_elbow"/>
    <motor gear="25" joint="humanoid_left_shoulder1" name="humanoid_left_shoulder1"/>
    <motor gear="25" joint="humanoid_left_shoulder2" name="humanoid_left_shoulder2"/>
    <motor gear="25" joint="humanoid_left_elbow" name="humanoid_left_elbow"/>
