        <joint name="humanoid_abdomen_z" armature="0.02" axis="0 0 1" damping="5" pos="0 0 0.065" range="-45 45" stiffness="20" type="hinge"/>
        <joint name="humanoid_abdomen_y" armature="0.02" axis="0 1 0" damping="5" pos="0 0 0.065" range="-75 30" stiffness="10" type="hinge"/>
        <body name="humanoid_pelvis" pos="0 0 -0.165" quat="1.000 0 -0.002 0">
          <joint name="humanoid_abdomen_x" armature="0.02" axis="1 0 0" damping="5" pos="0 0 0.1" range="-35 35" stiffness="10" type="hinge"/>
          <geom name="humanoid_butt" fromto="-.02 -.07 0 -.02 .07 0" size="0.09" type="capsule"/>
          <body name="humanoid_right_thigh" pos="0 -0.1 -0.04">
            <joint name="humanoid_right_hip_x" armature="0.01" axis="1 0 0" damping="5" pos="0 0 0" range="-25 5" stiffness="10" type="hinge"/>
            <joint name="humanoid_right_hip_z" armature="0.01" axis="0 0 1" damping="5" pos="0 0 0" range="-60 35" stiffness="10" type="hinge"/>
